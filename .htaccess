RewriteEngine On

# --- SECURITY: Block access to sensitive files and directories ---
# Block .env, .git, composer files, artisan, etc.
RewriteRule ^\.env - [F,L]
RewriteRule ^\.git - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
RewriteRule ^package(-lock)?\.json$ - [F,L]
RewriteRule ^artisan$ - [F,L]
RewriteRule ^phpunit\.xml$ - [F,L]
RewriteRule ^webpack\.config\.js$ - [F,L]
RewriteRule ^vite\.config\.js$ - [F,L]
RewriteRule ^tsconfig\.json$ - [F,L]
RewriteRule ^\.htaccess$ - [F,L]
RewriteRule ^storage/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^app/ - [F,L]
RewriteRule ^bootstrap/ - [F,L]
RewriteRule ^resources/ - [F,L]
RewriteRule ^routes/ - [F,L]
RewriteRule ^tests/ - [F,L]
RewriteRule ^vendor/ - [F,L]
RewriteRule ^node_modules/ - [F,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Rewrite all requests to public/
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ /public/$1 [L,QSA]